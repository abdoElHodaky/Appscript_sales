# Google Apps Script Configuration
# نسخة هذا الملف إلى .env وملء القيم الفعلية

# Google Apps Script Script ID (من URL المشروع)
SCRIPT_ID=your_script_id_here

# GCP Project ID (اختياري)
GCP_PROJECT_ID=your_gcp_project_id_here

# Admin emails (comma-separated)
# إيميلات المشرفين (مفصولة بفواصل)
ADMIN_EMAILS=admin@company.com,manager@company.com

# WhatsApp API (Ultramsg) - اختياري
# احفظ في Script Properties بدلاً من هنا
# ULTRAMSG_TOKEN=your_ultramsg_token_here

# Environment
NODE_ENV=development
